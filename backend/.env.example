# ---------- Server ----------
SERVER_PORT=8080

# ---------- Database ----------
DB_URL=jdbc:mysql://127.0.0.1:3306/digital_cyber_seva?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
DB_USERNAME=dcs_user
DB_PASSWORD=change_me

# ---------- JWT ----------
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# ---------- CORS ----------
# Comma-separated list
APP_CORS_ADDITIONAL_ORIGIN_PATTERNS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8100,http://127.0.0.1:8100,http://localhost:8081,http://127.0.0.1:8081

# ---------- Storage ----------
# local | cloudinary
STORAGE_PROVIDER=local
STORAGE_FALLBACK_TO_LOCAL=true

# Needed only if STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

LOCAL_STORAGE_BASE_PATH=uploads
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:8080/uploads

# ---------- Upload limits ----------
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB

# ---------- Cleanup schedules ----------
ACCOUNT_DELETION_RETENTION_DAYS=7
ACCOUNT_DELETION_CLEANUP_CRON=0 30 2 * * *
ACCOUNT_DELETION_CLEANUP_ZONE=Asia/Kolkata

RECORDS_RETENTION_DAYS=30
RECORDS_ARCHIVE_CRON=0 15 3 * * *
RECORDS_ARCHIVE_ZONE=Asia/Kolkata
RECORDS_ARCHIVE_DIRECTORY=archives/past-records
RECORDS_CLEANUP_CRON=0 45 3 * * *
RECORDS_CLEANUP_ZONE=Asia/Kolkata
