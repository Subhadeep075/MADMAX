    {
      "name": "Account Deletion",
      "item": [
        {
          "name": "Request Account Deletion (Customer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"reason\": \"I no longer need this account\"\\n}"
            },
            "url": "{{baseUrl}}/api/account-deletion/request"
          }
        },
        {
          "name": "Get My Deletion Status (Customer)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/account-deletion/status"
          }
        },
        {
          "name": "List Account Deletion Requests (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length) {",
                  "  const pending = data.find((x) => x.status === \"PENDING\");",
                  "  const target = pending || data[0];",
                  "  if (target && target.id) {",
                  "    pm.collectionVariables.set(\"deletionRequestId\", target.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/account-deletion"
          }
        },
        {
          "name": "Approve Account Deletion Request (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"remarks\": \"Approved after verification\"\\n}"
            },
            "url": "{{baseUrl}}/api/admin/account-deletion/{{deletionRequestId}}/approve"
          }
        },
        {
          "name": "Reject Account Deletion Request (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"remarks\": \"Rejected due to compliance review\"\\n}"
            },
            "url": "{{baseUrl}}/api/admin/account-deletion/{{deletionRequestId}}/reject"
          }
        }
      ]
